# ─── Flask ───────────────────────────────────────────────────────
SECRET_KEY=change-this-in-production

# ─── Gemini ──────────────────────────────────────────────────────
GEMINI_KEY=your-gemini-api-key

# ─── Aiven PostgreSQL ─────────────────────────────────────────────
# Get from: https://console.aiven.io → your service → Connection info
# Copy the "Service URI" (includes ?sslmode=require)
DATABASE_URL=postgresql://avnadmin:password@yourhost.aivencloud.com:12345/defaultdb?sslmode=require

# ─── TryChroma Cloud ──────────────────────────────────────────────
# Get from: https://trychroma.com → Dashboard → API Keys
CHROMA_API_KEY=chma-xxxxxxxxxxxxxxxx
CHROMA_TENANT=your-tenant-id
CHROMA_DATABASE=default

# ─── Google OAuth ─────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ─── Frontend URL (where Flask redirects after OAuth) ─────────────
FRONTEND_URL=http://localhost:5173

# ─── Optional: override allowed CORS origins ──────────────────────
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com
